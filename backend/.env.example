PORT=3000
DB_NAME=techxchange
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432
DB_LOGGING=false

# SePay webhook config
# Nếu set thì webhook bắt buộc header: Authorization: Apikey <SEPAY_API_KEY>
SEPAY_API_KEY=
# Format mã đơn trong nội dung/code SePay, mặc định: ORDER_<orderId>
SEPAY_ORDER_CODE_PREFIX=ORDER_
# Thông tin nhận chuyển khoản để generate QR cho FE
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_CODE=Vietcombank
SEPAY_ACCOUNT_NAME=
SEPAY_VIRTUAL_ACCOUNT=
SEPAY_REQUIRE_SUB_ACCOUNT=true

# GHN shipping config
# Production: https://online-gateway.ghn.vn
# Staging: https://dev-online-gateway.ghn.vn
GHN_BASE_URL=https://online-gateway.ghn.vn
GHN_TOKEN=
GHN_SHOP_ID=
GHN_STATUS_SYNC_INTERVAL_SECONDS=120

# AWS S3 upload config
AWS_REGION=us-east-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Ví dụ: https://techxchange-bucket.s3.us-east-2.amazonaws.com
AWS_S3_PUBLIC_BASE_URL=

# JWT
JWT_SECRET=your-secret-key-123

# AI recommendation service (Python FastAPI)
RECOMMENDATION_SERVICE_URL=http://localhost:8010
RECOMMENDATION_SERVICE_TIMEOUT_MS=5000
